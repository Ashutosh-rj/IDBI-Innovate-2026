# ==============================================================================
# IDBI Innovate 2026: MSME Financial Health Score Platform
# Environment Configuration Example (.env.example)
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file to `.env`: cp .env.example .env
# 2. Replace all default passwords and secrets before deploying to PRODUCTION.
# 3. In PRODUCTION environment, the services will strictly abort startup if default
#    or weak secrets are detected!
# ==============================================================================

# --- Environment & Mode ---
# Options: development, staging, production
ENVIRONMENT=development
APP_DATA_MODE=sandbox

# --- PostgreSQL Database Configuration ---
POSTGRES_DB=msme_health
POSTGRES_USER=msme_admin
# WARNING: Replace default password in production!
POSTGRES_PASSWORD=msme_secure_password_2026

# --- Redis Cache Configuration ---
# WARNING: Replace default password in production!
REDIS_PASSWORD=msme_redis_secret

# --- API Gateway JWT Signing Secret ---
# Must be at least 256 bits (32 characters). Replace in production!
JWT_SECRET=idbi_innovate_2026_super_secret_jwt_signing_key_at_least_256_bits

# --- Grafana Dashboard Credentials ---
GRAFANA_ADMIN_USER=admin
# WARNING: Replace default password in production!
GRAFANA_ADMIN_PASSWORD=msme_grafana_admin

# --- External Service Adapters ---
OCEN_SANDBOX_URL=https://sandbox.ocen.dev/v4/credit-passport
