{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://msme-health-score.idbi.co.in/contracts/v1/score-result.schema.json",
  "title": "MSME Financial Health Score Result",
  "description": "Output of the ML Scoring Engine. Contains composite score (0-1000), 5 sub-scores, SHAP feature attributions, human-readable reason codes ranked by magnitude, and confidence intervals.",
  "type": "object",
  "required": ["msmeId", "healthScore", "riskBand", "subScores", "isNtcThinFile", "dataQualityScore"],
  "properties": {
    "scoreId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this scoring computation"
    },
    "msmeId": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "healthScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1000,
      "description": "Overall financial health score on a 0-1000 scale"
    },
    "compositeScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1000
    },
    "riskBand": {
      "type": "string",
      "enum": ["PRIME_LOW_RISK", "STANDARD_MODERATE_RISK", "SUBPRIME_HIGH_RISK", "HIGH_RISK_REJECT", "EXCELLENT", "GOOD", "FAIR", "POOR", "HIGH_RISK", "MODERATE_RISK"],
      "description": "Categorical risk band based on composite score and fraud checks"
    },
    "scoreBand": {
      "type": "string"
    },
    "defaultProbability12m": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "isNtcThinFile": {
      "type": "boolean",
      "description": "True if the entity is New-to-Credit (NTC) / thin-file"
    },
    "ntcFlag": {
      "type": "boolean"
    },
    "subScores": {
      "type": "object",
      "properties": {
        "taxComplianceScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "cashFlowVelocityScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "payrollStabilityScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "businessVintageScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "liquidityBufferScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "gstCompliance": { "type": "number", "minimum": 0, "maximum": 100 },
        "cashFlowStability": { "type": "number", "minimum": 0, "maximum": 100 },
        "payrollStability": { "type": "number", "minimum": 0, "maximum": 100 },
        "digitalFootprint": { "type": "number", "minimum": 0, "maximum": 100 },
        "creditBehavior": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "topReasonCodes": {
      "type": "array"
    },
    "reasonCodes": {
      "type": "array"
    },
    "ocenEligibility": {
      "type": "object"
    },
    "fraudAnalysis": {
      "type": "object"
    },
    "shapReconciliation": {
      "type": "object"
    },
    "modelVersion": {
      "type": "string"
    },
    "dataQualityScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    }
  },
  "additionalProperties": true
}
