{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://msme-health-score.idbi.co.in/contracts/v1/gst-filing.schema.json",
  "title": "GST Filing Record (GSTR-3B)",
  "description": "Represents a single GSTR-3B monthly return filing. Field names and structure mirror the GSTN Developer Portal schema. Compliance metadata (filing_status, filing_date, due_date) is appended for scoring use.",
  "type": "object",
  "required": ["gstin", "supDetails", "filingStatus"],
  "properties": {
    "filingId": {
      "type": "string",
      "format": "uuid",
      "description": "Internal unique identifier for this filing record"
    },
    "msmeId": {
      "type": "string",
      "description": "Reference to the MSME entity"
    },
    "gstin": {
      "type": "string"
    },
    "retPeriod": {
      "type": "string",
      "description": "Return period in MMYYYY or YYYY-MM format as per GSTN"
    },
    "supDetails": {
      "type": "object",
      "description": "Table 3.1: Outward and inward supply details",
      "required": ["osupDet"],
      "properties": {
        "osupDet": {
          "$ref": "#/$defs/taxBreakdown",
          "description": "Outward taxable supplies (other than zero-rated, nil-rated, exempted)"
        },
        "osupZero": {
          "$ref": "#/$defs/taxBreakdown",
          "description": "Outward taxable supplies (zero rated)"
        },
        "osupNilExmp": {
          "$ref": "#/$defs/taxBreakdown",
          "description": "Nil-rated and exempted outward supplies"
        },
        "isupRev": {
          "$ref": "#/$defs/taxBreakdown",
          "description": "Inward supplies liable to reverse charge"
        },
        "osupNongst": {
          "$ref": "#/$defs/taxBreakdown",
          "description": "Non-GST outward supplies"
        }
      }
    },
    "interSup": {
      "type": "object",
      "description": "Table 3.2: Inter-state supplies to unregistered persons, composition taxpayers, UIN holders",
      "properties": {
        "unregDetails": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "pos": { "type": "string", "description": "Place of supply (2-digit state code)" },
              "txval": { "type": "number", "minimum": 0 },
              "iamt": { "type": "number", "minimum": 0 }
            }
          }
        },
        "compDetails": { "type": "array", "items": { "type": "object" } },
        "uinDetails": { "type": "array", "items": { "type": "object" } }
      }
    },
    "itcElg": {
      "type": "object",
      "description": "Table 4: Eligible Input Tax Credit",
      "required": ["itcNet"],
      "properties": {
        "itcAvl": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ty"],
            "properties": {
              "ty": { "type": "string", "enum": ["ISRC", "IMPG", "ISD", "OTH"], "description": "ITC type" },
              "iamt": { "type": "number", "minimum": 0 },
              "camt": { "type": "number", "minimum": 0 },
              "samt": { "type": "number", "minimum": 0 },
              "csamt": { "type": "number", "minimum": 0 }
            }
          }
        },
        "itcRev": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ty": { "type": "string", "enum": ["RUL", "OTH"] },
              "iamt": { "type": "number", "minimum": 0 },
              "camt": { "type": "number", "minimum": 0 },
              "samt": { "type": "number", "minimum": 0 },
              "csamt": { "type": "number", "minimum": 0 }
            }
          }
        },
        "itcNet": {
          "$ref": "#/$defs/taxAmounts",
          "description": "Net ITC available (avl - rev)"
        },
        "itcInelg": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ty": { "type": "string", "enum": ["RUL", "OTH"] },
              "iamt": { "type": "number", "minimum": 0 },
              "camt": { "type": "number", "minimum": 0 },
              "samt": { "type": "number", "minimum": 0 },
              "csamt": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    },
    "inwardSup": {
      "type": "object",
      "description": "Table 5: Exempt, nil-rated, and non-GST inward supplies",
      "properties": {
        "isupDetails": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ty": { "type": "string", "enum": ["GST", "NONGST"] },
              "inter": { "type": "number", "minimum": 0 },
              "intra": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    },
    "filingStatus": {
      "type": "string",
      "enum": ["ON_TIME", "LATE", "NOT_FILED", "NIL_RETURN"],
      "description": "Compliance status of this filing relative to its due date"
    },
    "filingDate": {
      "type": ["string", "null"],
      "format": "date",
      "description": "Actual date of filing (null if NOT_FILED)"
    },
    "dueDate": {
      "type": "string",
      "format": "date",
      "description": "Statutory due date for this return period (20th of following month)"
    },
    "filingDelayDays": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of days filed past due date (0 if on-time or early)"
    },
    "lateFeeAmount": {
      "type": "number",
      "minimum": 0,
      "description": "Late fee levied in INR (₹50/day normal, ₹20/day nil, capped per turnover slab)"
    },
    "source": {
      "type": "string",
      "enum": ["PRODUCTION", "SANDBOX"],
      "description": "Data source tag for audit trail — SANDBOX for synthetic, PRODUCTION for real GSTN fetch"
    },
    "fetchTimestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When this record was fetched/generated"
    }
  },
  "$defs": {
    "taxAmounts": {
      "type": "object",
      "properties": {
        "iamt": { "type": "number", "minimum": 0, "description": "IGST amount" },
        "camt": { "type": "number", "minimum": 0, "description": "CGST amount" },
        "samt": { "type": "number", "minimum": 0, "description": "SGST/UTGST amount" },
        "csamt": { "type": "number", "minimum": 0, "description": "Cess amount" }
      }
    },
    "taxBreakdown": {
      "type": "object",
      "required": ["txval"],
      "properties": {
        "txval": { "type": "number", "minimum": 0, "description": "Taxable value in INR" },
        "iamt": { "type": "number", "minimum": 0 },
        "camt": { "type": "number", "minimum": 0 },
        "samt": { "type": "number", "minimum": 0 },
        "csamt": { "type": "number", "minimum": 0 }
      }
    }
  },
  "additionalProperties": true
}
