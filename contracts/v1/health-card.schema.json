{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://msme-health-score.idbi.co.in/contracts/v1/health-card.schema.json",
  "title": "MSME Financial Health Card & OCEN LSP Payload",
  "description": "The published immutable Health Card artifact. Serves as both the visual dashboard data envelope and the OCEN LSP eligibility score payload.",
  "type": "object",
  "required": ["cardId", "msmeId", "version", "issuedAt", "scoreSnapshot", "trendHistory", "riskFlags", "recommendations", "ocenLspPayload", "auditHash"],
  "properties": {
    "cardId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this immutable health card version"
    },
    "msmeId": {
      "type": "string",
      "format": "uuid"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Sequential version number for audit trail"
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "scoreSnapshot": {
      "$ref": "score-result.schema.json"
    },
    "trendHistory": {
      "type": "array",
      "description": "Historical composite scores over the past 12 months",
      "items": {
        "type": "object",
        "required": ["month", "compositeScore"],
        "properties": {
          "month": { "type": "string", "pattern": "^\\d{4}-(0[1-9]|1[0-2])$" },
          "compositeScore": { "type": "number", "minimum": 0, "maximum": 1000 }
        }
      }
    },
    "riskFlags": {
      "type": "array",
      "description": "Automated risk flags derived from data anomalies or compliance lapses",
      "items": {
        "type": "object",
        "required": ["flagId", "severity", "category", "description", "detectedAt"],
        "properties": {
          "flagId": { "type": "string" },
          "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
          "category": { "type": "string", "enum": ["GST_MISMATCH", "LATE_FILING", "CASHFLOW_VOLATILITY", "EPFO_DEFAULT", "UDYAM_EXPIRY"] },
          "description": { "type": "string" },
          "detectedAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "description": "Actionable recommendations computed from lowest-performing SHAP features",
      "items": {
        "type": "object",
        "required": ["recId", "targetSubScore", "title", "action", "expectedScoreLift"],
        "properties": {
          "recId": { "type": "string" },
          "targetSubScore": { "type": "string" },
          "title": { "type": "string" },
          "action": { "type": "string" },
          "expectedScoreLift": {
            "type": "number",
            "minimum": 0,
            "description": "Predicted increase in composite score if action is taken"
          }
        }
      }
    },
    "ocenLspPayload": {
      "type": "object",
      "description": "Formatted payload ready for OCEN CreateLoanApplication API handshake",
      "required": ["entityId", "eligibilityScore", "evidenceDocuments", "timestamp"],
      "properties": {
        "entityId": { "type": "string", "description": "Borrower entityId in OCEN ecosystem" },
        "loanProductId": { "type": "string" },
        "eligibilityScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1000,
          "description": "Mapped composite score"
        },
        "evidenceDocuments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["documentType", "documentIdentifier", "source", "format"],
            "properties": {
              "documentType": {
                "type": "string",
                "enum": ["PAN_CARD", "UDYAM_CERTIFICATE", "GST_RETURNS", "BANK_STATEMENT", "EPFO_REPORT", "HEALTH_CARD"]
              },
              "documentIdentifier": { "type": "string" },
              "source": { "type": "string", "enum": ["GSTN", "AA_REBIT", "EPFO", "UDYAM", "IDBI_HEALTH_CARD"] },
              "format": { "type": "string", "enum": ["JSON", "PDF", "XML"] }
            }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "auditHash": {
      "type": "string",
      "description": "SHA-256 cryptographic hash of the entire health card payload for tamper-evidence"
    }
  },
  "additionalProperties": false
}
